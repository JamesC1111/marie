{
  "name": "marie-harding-counselling-service",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "start": "node ./dist/server/entry.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "astro check",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "tsx --test tests/*.test.ts",
