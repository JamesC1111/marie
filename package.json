    "lighthouse": "node ./scripts/run-lighthouse.mjs",
    "check:links": "node ./scripts/check-links.mjs",
    "check:schema": "node ./scripts/check-schema.mjs",
    "check:a11y": "node ./scripts/check-a11y.mjs",
    "check:health": "node ./scripts/run-health-checks.mjs"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.4",
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "nodemailer": "^8.0.1",
    "tailwindcss": "^4.2.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@lhci/cli": "^0.15.1",
    "@types/nodemailer": "^7.0.3",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
