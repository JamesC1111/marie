---
import { ctaLinks, practiceContact, serviceSignals, urgentHelpText } from '../lib/site';
import Icon from './Icon.astro';
---

<footer class="mt-20 border-t border-slate-200 bg-slate-950 text-slate-100 print:hidden">
  <div class="mx-auto grid w-full max-w-6xl gap-10 px-5 py-12 md:grid-cols-[1.3fr_1fr_1fr] md:px-8">
    <section>
      <h2 class="text-lg font-semibold">Marie Harding Counselling Service</h2>
      <p class="mt-3 max-w-xl text-sm leading-relaxed text-slate-300">
        Confidential counselling support in Kanturk, Co. Cork, with experience across private practice and the HSE.
      </p>
      <p class="mt-3 text-sm text-slate-300">{serviceSignals.supervision}</p>
    </section>

    <section>
      <h2 class="text-lg font-semibold">Contact</h2>
      <ul class="mt-3 space-y-2 text-sm text-slate-200">
        <li>
          <a class="inline-flex items-center gap-2 transition hover:text-white" href={ctaLinks.call}>
            <Icon name="phone" class="h-4 w-4" />
            {practiceContact.phoneDisplay}
          </a>
        </li>
        <li>
          <a class="inline-flex items-center gap-2 transition hover:text-white" href={ctaLinks.email}>
            <Icon name="email" class="h-4 w-4" />
            {practiceContact.email}
          </a>
        </li>
        <li class="inline-flex items-start gap-2">
          <Icon name="location" class="mt-0.5 h-4 w-4" />
          <span>{practiceContact.addressLine1}, {practiceContact.addressLine2}</span>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-lg font-semibold">Quick links</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="transition hover:text-white" href="/how-counselling-works">How counselling works</a></li>
        <li><a class="transition hover:text-white" href="/services">Services</a></li>
        <li><a class="transition hover:text-white" href="/contact">Request appointment</a></li>
        <li><a class="transition hover:text-white" href="/privacy-policy">Privacy policy</a></li>
        <li><a class="transition hover:text-white" href="/terms-of-use">Terms of use</a></li>
        <li><a class="transition hover:text-white" href="/accessibility-statement">Accessibility statement</a></li>
      </ul>
    </section>
  </div>

  <div class="border-t border-slate-800">
    <div class="mx-auto w-full max-w-6xl px-5 py-4 text-sm text-slate-300 md:px-8">
      <p><strong class="font-semibold text-white">Urgent help:</strong> {urgentHelpText}</p>
      <p class="mt-2">This service is not an emergency or crisis service.</p>
    </div>
  </div>
</footer>
