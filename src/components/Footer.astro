---
import {
  ctaLinks,
  localSupportLinks,
  practiceContact,
  serviceSignals,
  urgentHelpText,
  urgentSupportLinks
} from '../lib/site';
import Icon from './Icon.astro';
---

<footer class="site-footer mt-20 border-t border-slate-200 bg-slate-950 text-slate-100">
  <div class="container grid gap-10 py-12 md:grid-cols-[1.3fr_1fr_1fr]">
    <section>
      <h2 class="text-lg font-semibold">Marie Harding Counselling Service</h2>
      <p class="mt-3 max-w-xl text-sm leading-relaxed text-slate-300">
        Calm, confidential counselling support in Kanturk, Co. Cork, with longstanding private-practice and HSE experience.
      </p>
      <p class="mt-3 text-sm text-slate-300">{serviceSignals.supervision}</p>
    </section>

    <section>
      <h2 class="text-lg font-semibold">Contact</h2>
      <ul class="mt-3 space-y-3 text-sm text-slate-200">
        <li>
          <a class="footer-link inline-flex items-center gap-2" href={ctaLinks.call}>
            <Icon name="phone" class="h-4 w-4" />
            {practiceContact.phoneDisplay}
          </a>
        </li>
        <li>
          <a class="footer-link inline-flex items-center gap-2" href={ctaLinks.email}>
            <Icon name="email" class="h-4 w-4" />
            {practiceContact.email}
          </a>
        </li>
        <li class="inline-flex items-start gap-2">
          <Icon name="location" class="mt-0.5 h-4 w-4" />
          <span>{practiceContact.addressLine1}, {practiceContact.addressLine2}</span>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-lg font-semibold">Start here</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="footer-link" href="/how-counselling-works">How counselling works</a></li>
        <li><a class="footer-link" href="/about-marie">About Marie</a></li>
        <li><a class="footer-link" href="/services">Services</a></li>
        <li><a class="footer-link" href="/contact">Request appointment</a></li>
        <li><a class="footer-link" href="/resources">Resources</a></li>
      </ul>
    </section>
  </div>

  <div class="border-t border-slate-800">
    <div class="container grid gap-6 py-5 lg:grid-cols-[1.2fr_1fr]">
      <div class="text-sm text-slate-300">
        <p><strong class="font-semibold text-white">Urgent help:</strong> {urgentHelpText}</p>
        <p class="mt-2">This service is not an emergency or crisis service.</p>
        <p class="mt-2">You can also find additional Irish and Cork-relevant supports on the <a class="footer-link underline underline-offset-4" href="/resources">Resources</a> page.</p>
      </div>

      <div class="footer-support-grid text-sm text-slate-200">
        <a class="footer-support-card" href={urgentSupportLinks.emergency.href}>
          <strong>{urgentSupportLinks.emergency.display}</strong>
          <span>Emergency services</span>
        </a>
        <a class="footer-support-card" href={urgentSupportLinks.samaritans.href}>
          <strong>{urgentSupportLinks.samaritans.display}</strong>
          <span>Samaritans</span>
        </a>
        <a class="footer-support-card" href={urgentSupportLinks.pieta.href}>
          <strong>{urgentSupportLinks.pieta.display}</strong>
          <span>Pieta</span>
        </a>
        <a class="footer-support-card" href={urgentSupportLinks.hseUrgent.href} rel="noreferrer" target="_blank">
          <strong>HSE urgent help</strong>
          <span>Official guidance</span>
        </a>
        <a class="footer-support-card" href={localSupportLinks.corkSamaritans.href} rel="noreferrer" target="_blank">
          <strong>Cork Samaritans</strong>
          <span>Local branch</span>
        </a>
        <a class="footer-support-card" href={localSupportLinks.jigsawCork.href} rel="noreferrer" target="_blank">
          <strong>Jigsaw Cork</strong>
          <span>Young people</span>
        </a>
      </div>
    </div>
  </div>
</footer>
