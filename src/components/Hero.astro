---
import { ctaLinks, practiceContact, serviceSignals } from '../lib/site';
import Icon from './Icon.astro';

interface Props {
  title: string;
  intro: string;
  locationLine?: string;
}

const {
  title,
  intro,
  locationLine = 'Kanturk, Co. Cork'
} = Astro.props;
---

<section class="hero-shell">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="section-kicker">Marie Harding Counselling Service</p>
      <p class="hero-location">
        <Icon name="location" class="h-4 w-4" />
        {locationLine}
      </p>
      <h1 class="text-balance text-4xl font-semibold tracking-tight text-slate-900 md:text-5xl">{title}</h1>
      <p class="hero-lead">{intro}</p>
      <p class="hero-reassurance">You do not need to explain everything in your first message.</p>

      <div class="mt-7 flex flex-wrap gap-3">
        <a class="btn-primary" href={ctaLinks.call}>Call Marie</a>
        <a class="btn-secondary" href={ctaLinks.email}>Email Marie</a>
        <a class="btn-tertiary" href={ctaLinks.request} data-speculate="intent">Request appointment</a>
      </div>

      <div class="hero-links mt-6 flex flex-wrap gap-3 text-sm">
        <a class="link-subtle" href="/how-counselling-works" data-speculate="intent">How counselling works</a>
        <a class="link-subtle" href="/about-marie">About Marie</a>
        <a class="link-subtle" href="/services">Explore services</a>
      </div>
    </div>

    <aside class="hero-panel" aria-label="Practice overview">
      <p class="section-kicker">A steady first step</p>
      <ul class="hero-panel__list mt-5 space-y-4">
        <li>
          <strong>{serviceSignals.privatePracticeYears} years in private practice</strong>
          <span>Private practice since {serviceSignals.privatePracticeSince}.</span>
        </li>
        <li>
          <strong>{serviceSignals.hseYears} years with the HSE</strong>
          <span>Marie worked with the HSE from {serviceSignals.hseExperience}.</span>
        </li>
        <li>
          <strong>Accredited supervisor with the NAPCP</strong>
          <span>{serviceSignals.supervision}.</span>
        </li>
        <li>
          <strong>Practice based in {practiceContact.addressLine2}</strong>
          <span>{serviceSignals.openingNote}</span>
        </li>
      </ul>
      <p class="hero-panel__note mt-5">
        Confidentiality is of the utmost importance to me when working with clients.
      </p>
    </aside>
  </div>
</section>
