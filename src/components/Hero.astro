---
import { ctaLinks, practiceContact, serviceSignals } from '../lib/site';
import Icon from './Icon.astro';

interface Props {
  title: string;
  intro: string;
  locationLine?: string;
}

const {
  title,
  intro,
  locationLine = 'Kanturk, Co. Cork'
} = Astro.props;
---

<section class="relative overflow-hidden rounded-[2.2rem] border border-slate-200 bg-gradient-to-b from-white to-stone-50 p-6 shadow-sm md:p-8 lg:px-10">
  <div class="absolute -left-20 bottom-0 h-56 w-56 rounded-full bg-amber-100/80 blur-3xl" aria-hidden="true"></div>
  <div class="absolute -right-20 top-0 h-64 w-64 rounded-full bg-teal-100/80 blur-3xl" aria-hidden="true"></div>
  <div class="absolute left-1/3 top-6 hidden h-24 w-24 rounded-full border border-white/70 bg-white/20 blur-2xl lg:block" aria-hidden="true"></div>

  <div class="relative z-10 grid gap-8 lg:grid-cols-[minmax(0,1.5fr)_minmax(18rem,1fr)] lg:items-start">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Marie Harding Counselling Service</p>
      <p class="mt-3 inline-flex items-center gap-2 rounded-full border border-teal-200 bg-teal-50 px-3 py-1 text-sm font-medium text-teal-900">
        <Icon name="location" class="h-4 w-4" />
        {locationLine}
      </p>
      <h1 class="mt-4 max-w-3xl text-balance text-4xl font-semibold tracking-tight text-slate-900 md:text-5xl">{title}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-700">{intro}</p>
      <p class="mt-4 max-w-xl text-sm text-slate-600">You do not need to explain everything in your first message.</p>

      <div class="mt-7 flex flex-wrap gap-3">
        <a class="inline-flex items-center justify-center rounded-full border border-transparent bg-teal-800 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-900" href={ctaLinks.call}>Call Marie</a>
        <a class="inline-flex items-center justify-center rounded-full border border-teal-200 bg-teal-50 px-4 py-3 text-sm font-semibold text-teal-900 transition hover:border-teal-300 hover:bg-teal-100" href={ctaLinks.email}>Email Marie</a>
        <a class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-slate-50" href={ctaLinks.request} data-speculate="intent">Request appointment</a>
      </div>

      <div class="mt-6 flex flex-wrap gap-4 text-sm">
        <a class="font-medium text-teal-800 underline underline-offset-4 transition hover:text-teal-900" href="/how-counselling-works" data-speculate="intent">How counselling works</a>
        <a class="font-medium text-teal-800 underline underline-offset-4 transition hover:text-teal-900" href="/about-marie">About Marie</a>
        <a class="font-medium text-teal-800 underline underline-offset-4 transition hover:text-teal-900" href="/services">Explore services</a>
      </div>
    </div>

    <aside class="rounded-[1.9rem] border border-slate-200 bg-white/88 p-6 shadow-sm backdrop-blur" aria-label="Practice overview">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">A steady first step</p>
      <ul class="mt-5 space-y-4">
        <li class="border-t border-slate-200 pt-4 first:border-t-0 first:pt-0">
          <strong class="block text-base text-slate-950">{serviceSignals.privatePracticeYears} years in private practice</strong>
          <span class="mt-1 block text-sm leading-7 text-slate-600">Private practice since {serviceSignals.privatePracticeSince}.</span>
        </li>
        <li class="border-t border-slate-200 pt-4">
          <strong class="block text-base text-slate-950">{serviceSignals.hseYears} years with the HSE</strong>
          <span class="mt-1 block text-sm leading-7 text-slate-600">Marie worked with the HSE from {serviceSignals.hseExperience}.</span>
        </li>
        <li class="border-t border-slate-200 pt-4">
          <strong class="block text-base text-slate-950">APCP and ACI accredited supervisor</strong>
          <span class="mt-1 block text-sm leading-7 text-slate-600">{serviceSignals.supervision}.</span>
        </li>
        <li class="border-t border-slate-200 pt-4">
          <strong class="block text-base text-slate-950">Practice based in {practiceContact.addressLine2}</strong>
          <span class="mt-1 block text-sm leading-7 text-slate-600">{serviceSignals.openingNote}</span>
        </li>
      </ul>
      <p class="mt-5 text-sm leading-7 text-slate-600">
        Confidentiality is of the utmost importance to me when working with clients.
      </p>
    </aside>
  </div>
</section>
