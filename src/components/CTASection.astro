---
import { ctaLinks, practiceContact } from '../lib/site';
import Icon from './Icon.astro';

interface Props {
  title?: string;
  intro?: string;
}

const {
  title = 'If you would like to ask about availability, you can contact me by phone or email.',
  intro = 'A short message is enough. You are welcome to make contact in whichever way feels easiest for you.'
} = Astro.props;
---

<section class="section-shell px-6 py-7 md:px-8 md:py-8">
  <p class="section-kicker">Make contact</p>
  <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">{title}</h2>
  <p class="mt-3 max-w-3xl text-slate-700">{intro}</p>
  <div class="mt-5 flex flex-wrap gap-3">
    <a class="btn-primary inline-flex items-center gap-2" href={ctaLinks.call}>
      <Icon name="phone" class="h-4 w-4" />
      Call {practiceContact.phoneDisplay}
    </a>
    <a class="btn-secondary inline-flex items-center gap-2" href={ctaLinks.email}>
      <Icon name="email" class="h-4 w-4" />
      Email Marie
    </a>
    <a class="btn-tertiary" href={ctaLinks.request} data-speculate="intent">Request appointment</a>
  </div>
</section>
