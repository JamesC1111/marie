---
import { ctaLinks, practiceContact } from '../lib/site';
import Icon from './Icon.astro';

interface Props {
  title?: string;
  intro?: string;
}

const {
  title = 'If you would like to ask about availability, you can contact me by phone or email.',
  intro = 'You are welcome to make contact in whichever way feels easiest for you.'
} = Astro.props;
---

<section class="rounded-[2rem] border border-slate-200 bg-white/90 px-6 py-7 shadow-sm md:px-8">
  <div class="max-w-3xl">
    <h2 class="text-2xl font-semibold tracking-tight text-slate-900">{title}</h2>
    <p class="mt-3 text-slate-700">{intro}</p>
  </div>

  <div class="mt-6 grid gap-3 md:grid-cols-3">
    <a class="inline-flex min-h-[3.25rem] items-center justify-center gap-2 rounded-[1.4rem] border border-transparent bg-teal-800 px-4 py-3 text-center text-sm font-semibold text-white shadow-sm transition hover:bg-teal-900" href={ctaLinks.call}>
      <Icon name="phone" class="h-4 w-4" />
      Call {practiceContact.phoneDisplay}
    </a>
    <a class="inline-flex min-h-[3.25rem] items-center justify-center gap-2 rounded-[1.4rem] border border-teal-200 bg-teal-50 px-4 py-3 text-center text-sm font-semibold text-teal-900 transition hover:border-teal-300 hover:bg-teal-100" href={ctaLinks.email}>
      <Icon name="email" class="h-4 w-4" />
      Email Marie
    </a>
    <a class="inline-flex min-h-[3.25rem] items-center justify-center rounded-[1.4rem] border border-slate-300 bg-white px-4 py-3 text-center text-sm font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-slate-50" href={ctaLinks.request}>Request appointment</a>
  </div>
</section>
