---
import Icon from './Icon.astro';

interface Props {
  title: string;
  summary: string;
  href: string;
}

const { title, summary, href } = Astro.props;
---

<article class="card group service-card h-full">
  <p class="section-kicker text-[0.72rem]">Support area</p>
  <h3 class="mt-2 text-xl font-semibold text-slate-900">{title}</h3>
  <p class="mt-3 leading-relaxed text-slate-700">{summary}</p>
  <a
    class="service-card__link mt-6 inline-flex items-center gap-2 text-sm font-semibold text-teal-900"
    href={href}
    aria-label={`Read about ${title}`}
  >
    Read about {title}
    <Icon name="arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
  </a>
</article>
