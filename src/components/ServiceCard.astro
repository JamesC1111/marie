---
import Icon from './Icon.astro';

interface Props {
  title: string;
  summary: string;
  href: string;
}

const { title, summary, href } = Astro.props;
---

<article class="group flex h-full flex-col rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
  <h3 class="text-xl font-semibold text-slate-900">{title}</h3>
  <p class="mt-3 leading-relaxed text-slate-700">{summary}</p>
  <a
    class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-teal-800 transition hover:text-teal-900"
    href={href}
  >
    Read about {title}
    <Icon name="arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
  </a>
</article>
