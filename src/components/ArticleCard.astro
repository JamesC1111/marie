---
interface Props {
  title: string;
  summary: string;
  href: string;
  label: string;
  meta: string;
}

const { title, summary, href, label, meta } = Astro.props;
---

<article class="article-card">
  <p class="section-kicker text-[0.72rem]">{label}</p>
  <h3 class="mt-2 text-xl font-semibold text-slate-900">
    <a class="article-card__title" href={href}>{title}</a>
  </h3>
  <p class="article-card__meta mt-3">{meta}</p>
  <p class="mt-3 leading-relaxed text-slate-700">{summary}</p>
  <a
    class="service-card__link mt-6 inline-flex items-center gap-2 text-sm font-semibold text-teal-900"
    href={href}
    aria-label={`Read ${title}`}
  >
    Read {title}
  </a>
</article>
