---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="text-sm" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2 text-slate-600">
    {items.map((item, index) => (
      <li class="inline-flex items-center gap-2">
        {index > 0 && <span aria-hidden="true" class="text-slate-400">/</span>}
        {item.href ? (
          <a class="link-subtle" href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page" class="font-medium text-slate-800">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
