---
import { urgentSupportLinks } from '../lib/site';

interface Props {
  title?: string;
  intro?: string;
}

const {
  title = 'Need urgent or additional support?',
  intro = 'This practice is not an emergency or crisis service. If you need urgent help, use one of these supports or visit the full resources page.'
} = Astro.props;
---

<section class="support-panel" aria-labelledby="support-panel-title">
  <div class="support-panel__header">
    <p class="section-kicker">Support resources</p>
    <h2 id="support-panel-title" class="mt-2 text-2xl font-semibold tracking-tight text-slate-950">
      {title}
    </h2>
    <p class="mt-3 max-w-3xl text-slate-700">{intro}</p>
  </div>

  <div class="support-panel__grid mt-6">
    <article class="support-card support-card--alert">
      <h3 class="text-lg font-semibold text-amber-950">Urgent help</h3>
      <ul class="mini-list mt-4">
        <li>
          <a class="link-subtle" href={urgentSupportLinks.emergency.href}>
            Call {urgentSupportLinks.emergency.display}
          </a>
        </li>
        <li>
          <a class="link-subtle" href={urgentSupportLinks.samaritans.href}>
            Samaritans {urgentSupportLinks.samaritans.display}
          </a>
        </li>
        <li>
          <a class="link-subtle" href={urgentSupportLinks.pieta.href}>
            Pieta {urgentSupportLinks.pieta.display}
          </a>
          {' '}or{' '}
          <a class="link-subtle" href={urgentSupportLinks.pieta.textHref}>
            {urgentSupportLinks.pieta.textDisplay}
          </a>
        </li>
        <li>
          <a
            class="link-subtle"
            href={urgentSupportLinks.hseUrgent.href}
            rel="noreferrer"
            target="_blank"
          >
            HSE urgent mental health help
          </a>
        </li>
      </ul>
    </article>

    <article class="support-card">
      <h3 class="text-lg font-semibold text-slate-900">Additional support</h3>
      <p class="mt-3 text-slate-700">
        The resources page includes official Irish and Cork-relevant supports for young people,
        bereavement, peer support, family information, and general mental health guidance.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a class="btn-secondary" href="/resources">View support resources</a>
        <a class="btn-tertiary" href="/contact">Contact Marie</a>
      </div>
    </article>
  </div>
</section>
