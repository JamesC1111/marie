---
interface Props {
  name: 'phone' | 'email' | 'location' | 'arrow-right' | 'calendar' | 'clock';
  class?: string;
}

const { name, class: className = 'h-5 w-5' } = Astro.props;
---

{
  name === 'phone' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 5.5c0 7.2 5.8 13 13 13h2a1 1 0 0 0 1-1v-3.1a1 1 0 0 0-.8-1l-3.4-.7a1 1 0 0 0-1 .4l-1.3 1.6a10.7 10.7 0 0 1-4.8-4.8l1.6-1.3a1 1 0 0 0 .4-1l-.7-3.4a1 1 0 0 0-1-.8H5.5a1 1 0 0 0-1 1v2Z" />
    </svg>
  )
}

{
  name === 'email' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 6.8A1.8 1.8 0 0 1 4.8 5h14.4A1.8 1.8 0 0 1 21 6.8v10.4a1.8 1.8 0 0 1-1.8 1.8H4.8A1.8 1.8 0 0 1 3 17.2V6.8Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="m4 7 8 6 8-6" />
    </svg>
  )
}

{
  name === 'location' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s7-5.8 7-11a7 7 0 1 0-14 0c0 5.2 7 11 7 11Z" />
      <circle cx="12" cy="10" r="2.5" />
    </svg>
  )
}

{
  name === 'arrow-right' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
      <path stroke-linecap="round" stroke-linejoin="round" d="m13 6 6 6-6 6" />
    </svg>
  )
}

{
  name === 'calendar' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
      <rect x="3" y="5" width="18" height="16" rx="2" />
      <path d="M8 3v4M16 3v4M3 10h18" stroke-linecap="round" />
    </svg>
  )
}

{
  name === 'clock' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
