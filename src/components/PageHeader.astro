---
interface Props {
  title: string;
  intro?: string;
}

const { title, intro } = Astro.props;
---

<header class="border-b border-slate-200 pb-6">
  <h1 class="text-balance text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">{title}</h1>
  {intro && <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">{intro}</p>}
</header>
