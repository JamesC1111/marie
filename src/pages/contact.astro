---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';
import PageHeader from '../components/PageHeader.astro';
import { getContactDeliveryConfig } from '../lib/contact-delivery';
import { getRequestHost } from '../lib/request';
import Layout from '../layouts/Layout.astro';
import { localBusinessSchema } from '../lib/schema';
import { practiceContact, serviceSignals } from '../lib/site';

const status = Astro.url.searchParams.get('status');
const error = Astro.url.searchParams.get('error');
const requestHost = getRequestHost(Astro.request, Astro.url);
const contactDelivery = getContactDeliveryConfig(requestHost);
const formUnavailable = contactDelivery.mode === 'unavailable';
const alertCopy =
  status === 'success'
    ? 'Thank you. Your message has been sent. Marie will respond as soon as possible.'
    : error === 'validation'
      ? 'Please check the form and try again. Include your contact details and a short message.'
      : error === 'rate-limit'
        ? 'There have been too many attempts in a short time. Please wait a little while, or contact Marie by phone or email.'
        : error === 'service-unavailable'
          ? 'The online form is temporarily unavailable. Please call or email Marie directly.'
          : error
            ? 'Sorry, your message could not be sent right now. Please try again or contact Marie by phone or email.'
            : null;
---

<Layout
  title="Contact Marie Harding"
  description="Contact Marie Harding Counselling Service by phone, email, or appointment request form."
  canonicalPath="/contact"
  schema={[localBusinessSchema()]}
>
  <div class="space-y-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
    <PageHeader
      title="Contact"
      intro="If you would like to ask about availability, you can contact me by phone or email. Day and evening appointments."
    />
  </div>

  {alertCopy && (
    <section
      id="contact-status"
      class={`mt-8 rounded-xl border px-4 py-3 text-sm ${
        status === 'success'
          ? 'border-emerald-300 bg-emerald-50 text-emerald-900'
          : 'border-amber-300 bg-amber-50 text-amber-900'
      }`}
      aria-live={status === 'success' ? 'polite' : 'assertive'}
      role={status === 'success' ? 'status' : 'alert'}
      tabindex="-1"
    >
      {alertCopy}
    </section>
  )}

  <section class="mt-8 grid gap-8 lg:grid-cols-[1fr_1.2fr]">
    <aside class="space-y-4">
      <article class="card">
        <h2 class="text-xl font-semibold text-slate-900">Contact details</h2>
        <ul class="mt-4 space-y-3 text-slate-700">
          <li>
            <a class="inline-flex items-center gap-2 font-medium text-teal-900" href={`tel:+353872503743`}>
              <Icon name="phone" class="h-4 w-4" />
              Click to call: {practiceContact.phoneDisplay}
            </a>
          </li>
          <li>
            <a class="inline-flex items-center gap-2 font-medium text-teal-900" href={`mailto:${practiceContact.email}`}>
              <Icon name="email" class="h-4 w-4" />
              Tap to email: {practiceContact.email}
            </a>
          </li>
          <li class="inline-flex items-start gap-2">
            <Icon name="location" class="mt-0.5 h-4 w-4" />
            <span>{practiceContact.addressLine1}, {practiceContact.addressLine2}</span>
          </li>
        </ul>
        <p class="mt-4 text-slate-700">{serviceSignals.openingNote}</p>
      </article>

      <article class="card">
        <h2 class="text-xl font-semibold text-slate-900">Location map</h2>
        <p class="mt-2 text-sm text-slate-600">Plain text address: {practiceContact.addressLine1}, {practiceContact.addressLine2}</p>
        <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
          <iframe
            src={practiceContact.mapsEmbedUrl}
            title="Map to Marie Harding Counselling Service"
            loading="lazy"
            style="border:0; width:100%; min-height:260px;"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <a class="mt-3 inline-flex text-sm font-semibold text-teal-800 hover:underline" href={practiceContact.mapsLink} target="_blank" rel="noreferrer">
          Open map in Google Maps
        </a>
      </article>
    </aside>

    <section id="appointment-form" class="card">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Request an appointment</h2>
      {formUnavailable ? (
        <div class="mt-6 space-y-4 rounded-2xl border border-amber-300 bg-amber-50 p-4 text-slate-800" role="alert">
          <p class="font-medium text-amber-950">The online request form is temporarily unavailable.</p>
          <p>If you would like to ask about availability, please call or email Marie directly.</p>
          <div class="flex flex-wrap gap-3">
            <a class="btn-primary" href={`tel:+353872503743`}>Call Marie</a>
            <a class="btn-secondary" href={`mailto:${practiceContact.email}`}>Email Marie</a>
          </div>
        </div>
      ) : (
        <>
          <p class="mt-3 text-slate-700">Please do not include highly sensitive details in this form.</p>
          <p class="mt-1 text-sm text-slate-600">Messages are sent to email and are not stored on this website.</p>

          <form action="/api/contact" method="post" class="form-grid mt-6" novalidate>
            <div>
              <label for="name">Name</label>
              <input id="name" name="name" type="text" autocomplete="name" required maxlength="80" />
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="email">Email</label>
                <input id="email" name="email" type="email" autocomplete="email" maxlength="160" />
              </div>
              <div>
                <label for="phone">Phone</label>
                <input id="phone" name="phone" type="tel" inputmode="tel" autocomplete="tel" maxlength="40" />
              </div>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="preferredContact">Preferred contact method</label>
                <select id="preferredContact" name="preferredContact" required>
                  <option value="">Select one</option>
                  <option value="Phone">Phone</option>
                  <option value="Email">Email</option>
                  <option value="Either">Either</option>
                </select>
              </div>
              <div>
                <label for="preferredTimes">Preferred times</label>
                <input
                  id="preferredTimes"
                  name="preferredTimes"
                  type="text"
                  maxlength="120"
                  placeholder="Example: weekday evenings"
                />
              </div>
            </div>

            <div>
              <label for="message">Short message</label>
              <textarea id="message" name="message" required maxlength="1200"></textarea>
            </div>

            <div style="position:absolute;left:-9999px;opacity:0;pointer-events:none;" aria-hidden="true">
              <label for="company">Company</label>
              <input id="company" name="company" tabindex="-1" autocomplete="off" />
            </div>

            <div class="rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
              <label class="inline-flex items-start gap-2" for="consent">
                <input id="consent" name="consent" type="checkbox" required class="mt-1 h-4 w-4" />
                <span>I consent to being contacted by Marie Harding Counselling Service regarding this enquiry.</span>
              </label>
            </div>

            <button class="btn-primary w-fit" type="submit">Send request</button>
          </form>
        </>
      )}
    </section>
  </section>
</Layout>
