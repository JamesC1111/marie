---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CallbackCapture from '../components/CallbackCapture.astro';
import Icon from '../components/Icon.astro';
import PageHeader from '../components/PageHeader.astro';
import SupportPanel from '../components/SupportPanel.astro';
import { getContactDeliveryConfig } from '../lib/contact-delivery';
import { getRequestHost } from '../lib/request';
import { localBusinessSchema } from '../lib/schema';
import { practiceContact, serviceSignals } from '../lib/site';
import Layout from '../layouts/Layout.astro';

const status = Astro.url.searchParams.get('status');
const error = Astro.url.searchParams.get('error');
const requestHost = getRequestHost(Astro.request, Astro.url);
const contactDelivery = getContactDeliveryConfig(requestHost);
const formUnavailable = contactDelivery.mode === 'unavailable';
const alertCopy =
  status === 'success'
    ? 'Thank you. Your message has been sent. Marie will respond as soon as possible.'
    : error === 'validation'
      ? 'Please check the form and try again. Include your contact details and a short message.'
      : error === 'rate-limit'
        ? 'There have been too many attempts in a short time. Please wait a little while, or contact Marie by phone or email.'
        : error === 'service-unavailable'
          ? 'The online form is temporarily unavailable. Please call or email Marie directly.'
          : error
            ? 'Sorry, your message could not be sent right now. Please try again or contact Marie by phone or email.'
            : null;
---

<Layout
  title="Contact Marie Harding"
  description="Call, email, or request an appointment with Marie Harding Counselling Service in Kanturk, Co. Cork."
  canonicalPath="/contact"
  schema={[localBusinessSchema()]}
  showPageCta={false}
>
  <div class="space-y-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
    <PageHeader
      title="Contact"
      intro="If you would like to ask about availability, you can contact me by phone or email. You are welcome to keep your first message short. Day and evening appointments."
    />
  </div>

  {alertCopy && (
    <section
      id="contact-status"
      class={`mt-8 rounded-[1.25rem] border px-4 py-3 text-sm ${
        status === 'success'
          ? 'border-emerald-300 bg-emerald-50 text-emerald-900'
          : 'border-amber-300 bg-amber-50 text-amber-900'
      }`}
      aria-live={status === 'success' ? 'polite' : 'assertive'}
      role={status === 'success' ? 'status' : 'alert'}
      tabindex="-1"
    >
      {alertCopy}
    </section>
  )}

  <section class="contact-layout mt-8 grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
    <aside class="space-y-4">
      <div class="contact-method-grid contact-method-grid--stacked">
        <article class="contact-method-card">
          <p class="section-kicker">Phone</p>
          <h2 class="mt-2 text-xl font-semibold text-slate-900">Call Marie</h2>
          <p class="mt-3 text-slate-700">If speaking feels easier than writing, you can phone directly to ask about availability.</p>
          <a class="service-card__link mt-5 inline-flex items-center gap-2 text-sm font-semibold text-teal-900" href={`tel:+353872503743`}>
            <Icon name="phone" class="h-4 w-4" />
            {practiceContact.phoneDisplay}
          </a>
        </article>

        <article class="contact-method-card">
          <p class="section-kicker">Email</p>
          <h2 class="mt-2 text-xl font-semibold text-slate-900">Send an email</h2>
          <p class="mt-3 text-slate-700">A short message is enough if you would prefer to write first.</p>
          <a class="service-card__link mt-5 inline-flex items-center gap-2 text-sm font-semibold text-teal-900" href={`mailto:${practiceContact.email}`}>
            <Icon name="email" class="h-4 w-4" />
            {practiceContact.email}
          </a>
        </article>

        <article class="contact-method-card">
          <p class="section-kicker">Location</p>
          <h2 class="mt-2 text-xl font-semibold text-slate-900">Kanturk, Co. Cork</h2>
          <p class="mt-3 text-slate-700">Practice address: {practiceContact.addressLine1}, {practiceContact.addressLine2}. {serviceSignals.openingNote}</p>
          <a class="service-card__link mt-5 inline-flex items-center gap-2 text-sm font-semibold text-teal-900" href={practiceContact.mapsLink} target="_blank" rel="noreferrer">
            <Icon name="location" class="h-4 w-4" />
            Open in Google Maps
          </a>
        </article>
      </div>

      <article class="soft-panel">
        <p class="section-kicker">What helps in a first message</p>
        <ul class="mini-list mt-4">
          <li>Your name and preferred contact method.</li>
          <li>A short note about what kind of support you are looking for.</li>
          <li>Any days or times that usually suit you.</li>
        </ul>
        <p class="mt-4 text-sm text-slate-700">
          If you need urgent or additional support, the <a class="link-subtle" href="/resources">Resources</a> page lists official Irish and Cork-relevant supports.
        </p>
      </article>

      <article class="card overflow-hidden">
        <h2 class="text-xl font-semibold text-slate-900">Location map</h2>
        <p class="mt-2 text-sm text-slate-600">Plain text address: {practiceContact.addressLine1}, {practiceContact.addressLine2}</p>
        <div class="mt-4 overflow-hidden rounded-[1rem] border border-slate-200">
          <iframe
            src={practiceContact.mapsEmbedUrl}
            title="Map to Marie Harding Counselling Service"
            loading="lazy"
            style="border:0; width:100%; min-height:260px;"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </article>
    </aside>

    <section id="appointment-form" class="section-shell px-6 py-7 md:px-8 md:py-8">
      <p class="section-kicker">Request an appointment</p>
      <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">Send a short enquiry</h2>

      {formUnavailable ? (
        <div class="contact-note mt-6" role="alert">
          <p class="font-medium text-amber-950">The online request form is temporarily unavailable.</p>
          <p class="mt-2">If you would like to ask about availability, please call or email Marie directly.</p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a class="btn-primary" href={`tel:+353872503743`}>Call Marie</a>
            <a class="btn-secondary" href={`mailto:${practiceContact.email}`}>Email Marie</a>
          </div>
        </div>
      ) : (
        <>
          <p class="mt-4 text-slate-700">You are welcome to keep your first message brief. A few lines is enough.</p>
          <p class="mt-2 text-slate-700">Please do not include highly sensitive details in this form.</p>
          <p class="mt-1 text-sm text-slate-600">Messages are sent to email and are not stored on this website.</p>

          <form action="/api/contact" method="post" class="form-grid mt-6" novalidate>
            <div>
              <label for="name">Name</label>
              <input id="name" name="name" type="text" autocomplete="name" required maxlength="80" />
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="email">Email</label>
                <input id="email" name="email" type="email" autocomplete="email" maxlength="160" />
              </div>
              <div>
                <label for="phone">Phone</label>
                <input id="phone" name="phone" type="tel" inputmode="tel" autocomplete="tel" maxlength="40" />
              </div>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="preferredContact">Preferred contact method</label>
                <select id="preferredContact" name="preferredContact" required>
                  <option value="">Select one</option>
                  <option value="Phone">Phone</option>
                  <option value="Email">Email</option>
                  <option value="Either">Either</option>
                </select>
              </div>
              <div>
                <label for="preferredTimes">Preferred times</label>
                <input
                  id="preferredTimes"
                  name="preferredTimes"
                  type="text"
                  maxlength="120"
                  placeholder="Example: weekday evenings"
                />
              </div>
            </div>

            <div>
              <label for="message">Short message</label>
              <textarea id="message" name="message" required maxlength="1200"></textarea>
            </div>

            <div style="position:absolute;left:-9999px;opacity:0;pointer-events:none;" aria-hidden="true">
              <label for="company">Company</label>
              <input id="company" name="company" tabindex="-1" autocomplete="off" />
            </div>

            <div class="rounded-[1rem] border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
              <label class="inline-flex items-start gap-2" for="consent">
                <input id="consent" name="consent" type="checkbox" required class="mt-1 h-4 w-4" />
                <span>I consent to being contacted by Marie Harding Counselling Service regarding this enquiry.</span>
              </label>
            </div>

            <button class="btn-primary w-fit" type="submit">Send request</button>
          </form>
        </>
      )}
    </section>
  </section>

  <div class="mt-14">
    <CallbackCapture
      title="If you would prefer, leave your phone or email and Marie can get back to you"
      intro="You can use this shorter callback request if that feels easier than writing a full enquiry."
      returnPath="/contact"
    />
  </div>

  <div class="mt-14">
    <SupportPanel intro="If you are looking for urgent help or a wider support option alongside counselling, these official services may be useful." />
  </div>
</Layout>
