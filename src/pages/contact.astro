---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';
import PageHeader from '../components/PageHeader.astro';
import Layout from '../layouts/Layout.astro';
import { preferredContactOptions, preferredTimeOptionsByContact } from '../lib/contact-form';
import { localBusinessSchema } from '../lib/schema';
import { practiceContact, serviceSignals } from '../lib/site';

const status = Astro.url.searchParams.get('status');
const error = Astro.url.searchParams.get('error');
---

<Layout
  title="Contact Marie Harding"
  description="Contact Marie Harding Counselling Service by phone, email, or appointment request form."
  canonicalPath="/contact"
  schema={[localBusinessSchema()]}
>
  <div class="space-y-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
    <PageHeader
      title="Contact"
      intro="If you would like to ask about availability, you can contact me by phone or email. Day and evening appointments."
    />
  </div>

  {(status === 'success' || error) && (
    <section
      class={`mt-8 rounded-2xl border px-4 py-3 text-sm shadow-sm ${
        status === 'success'
          ? 'border-emerald-300 bg-emerald-50 text-emerald-900'
          : 'border-amber-300 bg-amber-50 text-amber-900'
      }`}
      aria-live="polite"
    >
      {status === 'success'
        ? 'Thank you. Your message has been sent. Marie will respond as soon as possible.'
        : 'Sorry, your message could not be sent right now. Please try again or contact by phone/email.'}
    </section>
  )}

  <section class="mt-8 grid gap-8 lg:grid-cols-[1fr_1.2fr]">
    <aside class="space-y-4">
      <article class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Contact details</h2>
        <ul class="mt-4 space-y-3 text-slate-700">
          <li>
            <a class="inline-flex items-center gap-2 font-medium text-teal-900 transition hover:text-teal-800" href={`tel:+353872503743`}>
              <Icon name="phone" class="h-4 w-4" />
              Click to call: {practiceContact.phoneDisplay}
            </a>
          </li>
          <li>
            <a class="inline-flex items-center gap-2 font-medium text-teal-900 transition hover:text-teal-800" href={`mailto:${practiceContact.email}`}>
              <Icon name="email" class="h-4 w-4" />
              Tap to email: {practiceContact.email}
            </a>
          </li>
          <li class="inline-flex items-start gap-2">
            <Icon name="location" class="mt-0.5 h-4 w-4" />
            <span>{practiceContact.addressLine1}, {practiceContact.addressLine2}</span>
          </li>
        </ul>
        <p class="mt-4 text-slate-700">{serviceSignals.openingNote}</p>
      </article>

      <article class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Location map</h2>
        <p class="mt-2 text-sm text-slate-600">Plain text address: {practiceContact.addressLine1}, {practiceContact.addressLine2}</p>
        <div class="mt-4 overflow-hidden rounded-2xl border border-slate-200">
          <iframe
            src={practiceContact.mapsEmbedUrl}
            title="Map to Marie Harding Counselling Service"
            loading="lazy"
            class="h-72 w-full border-0"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <a class="mt-3 inline-flex text-sm font-semibold text-teal-800 underline underline-offset-4 transition hover:text-teal-900" href={practiceContact.mapsLink} target="_blank" rel="noreferrer">
          Open map in Google Maps
        </a>
      </article>
    </aside>

    <section id="appointment-form" class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Request an appointment</h2>
      <p class="mt-3 text-slate-700">Please do not include highly sensitive details in this form.</p>
      <p class="mt-1 text-sm text-slate-600">Messages are sent to email and are not stored on this website.</p>
      <p class="mt-1 text-sm text-slate-600">Payment arrangements can be discussed after an initial consultation by phone or email.</p>

      <form action="/api/contact" method="post" class="mt-6 grid gap-4" novalidate>
        <div>
          <label class="block text-sm font-semibold text-slate-900" for="name">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            autocomplete="name"
            required
            maxlength="80"
            class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-teal-700 focus:ring-4 focus:ring-teal-100"
          />
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="block text-sm font-semibold text-slate-900" for="email">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              maxlength="160"
              class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-teal-700 focus:ring-4 focus:ring-teal-100"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-900" for="phone">Phone</label>
            <input
              id="phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              maxlength="40"
              class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-teal-700 focus:ring-4 focus:ring-teal-100"
            />
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="block text-sm font-semibold text-slate-900" for="preferredContact">Preferred contact method</label>
            <select
              id="preferredContact"
              name="preferredContact"
              required
              class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-teal-700 focus:ring-4 focus:ring-teal-100"
            >
              <option value="">Select one</option>
              {preferredContactOptions.map((option) => (
                <option value={option}>{option}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-900" for="preferredTimes">Preferred times</label>
            <select
              id="preferredTimes"
              name="preferredTimes"
              aria-describedby="preferred-times-help"
              class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm focus:border-teal-700 focus:ring-4 focus:ring-teal-100"
            >
              <option value="">Select one</option>
              {preferredContactOptions.map((contactOption) => (
                <optgroup label={`${contactOption} options`}>
                  {preferredTimeOptionsByContact[contactOption].map((option) => (
                    <option value={option.value}>{option.label}</option>
                  ))}
                </optgroup>
              ))}
            </select>
            <p id="preferred-times-help" class="mt-2 text-sm text-slate-600">
              Preferred time options update after you choose a contact method.
            </p>
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-900" for="message">Short message</label>
          <textarea
            id="message"
            name="message"
            required
            maxlength="1200"
            class="mt-2 min-h-32 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 shadow-sm placeholder:text-slate-500 focus:border-teal-700 focus:ring-4 focus:ring-teal-100"
          ></textarea>
        </div>

        <div style="position:absolute;left:-9999px;opacity:0;pointer-events:none;" aria-hidden="true">
          <label for="company">Company</label>
          <input id="company" name="company" tabindex="-1" autocomplete="off" />
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700">
          <label class="inline-flex items-start gap-2" for="consent">
            <input id="consent" name="consent" type="checkbox" required class="mt-1 h-4 w-4" />
            <span>I consent to being contacted by Marie Harding Counselling Service regarding this enquiry.</span>
          </label>
        </div>

        <button class="inline-flex w-fit items-center justify-center rounded-full border border-transparent bg-teal-800 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-900" type="submit">Send request</button>
      </form>
    </section>
  </section>

  <script is:inline define:vars={{ preferredTimeOptionsByContact }}>
    const preferredContact = document.getElementById('preferredContact');
    const preferredTimes = document.getElementById('preferredTimes');

    if (preferredContact instanceof HTMLSelectElement && preferredTimes instanceof HTMLSelectElement) {
      const optionsByContact = preferredTimeOptionsByContact;
      const buildOptions = (selectedContact) => {
        const previousValue = preferredTimes.value;
        const nextOptions = selectedContact ? optionsByContact[selectedContact] ?? [] : [];

        preferredTimes.innerHTML = '';
        preferredTimes.append(new Option('Select one', ''));

        for (const option of nextOptions) {
          preferredTimes.append(new Option(option.label, option.value));
        }

        const canReusePreviousValue = nextOptions.some((option) => option.value === previousValue);
        preferredTimes.value = canReusePreviousValue ? previousValue : '';
      };

      buildOptions(preferredContact.value);
      preferredContact.addEventListener('change', () => {
        buildOptions(preferredContact.value);
      });
    }
  </script>
</Layout>
