---
import { getCollection } from 'astro:content';

import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageHeader from '../../components/PageHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getEntrySlug } from '../../lib/content';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Counselling services"
  description="Explore counselling services offered by Marie Harding in Kanturk, Co. Cork."
  canonicalPath="/services"
>
  <div class="space-y-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Services' }]} />
    <PageHeader
      title="Services"
      intro="Support is available for a wide range of personal, family, and professional concerns."
    />
  </div>

  <p class="mt-8 max-w-3xl text-slate-700">
    If you are not sure which service is the best fit, that is completely fine.
    You can make contact and we can discuss what support may suit your needs.
  </p>

  <section class="mt-8">
    <h2 class="text-2xl font-semibold tracking-tight text-slate-900">
      Support available
    </h2>
    <div class="mt-5 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <div>
          <ServiceCard
            title={service.data.title}
            summary={service.data.summary}
            href={`/services/${getEntrySlug(service.id)}`}
          />
        </div>
      ))}
    </div>
  </section>
</Layout>
