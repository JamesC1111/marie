---
import { getCollection } from 'astro:content';

import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageHeader from '../../components/PageHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getEntrySlug } from '../../lib/content';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Counselling Services | Marie Harding"
  description="Explore counselling support with Marie Harding in Kanturk, Co. Cork, including addiction, grief, anxiety, relationships, supervision, and more."
  canonicalPath="/services"
>
  <div class="space-y-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Services' }]} />
    <PageHeader
      title="Services"
      intro="Support is available for a wide range of personal, family, and professional concerns. Many people find that more than one area overlaps, so you do not need to choose the perfect heading before making contact."
    />
  </div>

  <section class="soft-panel mt-8 px-6 py-6 md:px-8">
    <p class="text-slate-800">
      If you are unsure which description fits best, that is completely fine.
      You can contact Marie and discuss what support may suit your needs.
    </p>
  </section>

  <section class="mt-10">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-3xl">
        <p class="section-kicker">Support available</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">Areas of support</h2>
      </div>
      <a class="btn-tertiary" href="/how-counselling-works">How counselling works</a>
    </div>

    <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <ServiceCard
          title={service.data.title}
          summary={service.data.summary}
          href={`/services/${getEntrySlug(service.id)}/`}
        />
      ))}
    </div>
  </section>

  <section class="section-shell mt-14 px-6 py-8 md:px-8 md:py-10">
    <div class="max-w-3xl">
      <p class="section-kicker">Not sure where to begin?</p>
      <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">You can still get in touch</h2>
      <p class="mt-4 text-slate-700">
        You do not need to decide everything before making contact.
        A brief conversation about what is going on can help clarify the next step.
      </p>
    </div>

    <div class="feature-grid mt-8 md:grid-cols-3">
      <article class="feature-card">
        <h3 class="text-lg font-semibold text-slate-900">Keep it brief</h3>
        <p class="mt-3 text-slate-700">Your first message can simply ask about availability and whether the support sounds suitable.</p>
      </article>
      <article class="feature-card">
        <h3 class="text-lg font-semibold text-slate-900">Read the process first</h3>
        <p class="mt-3 text-slate-700">If you would like more detail before booking, the How counselling works page explains the first steps clearly.</p>
      </article>
      <article class="feature-card">
        <h3 class="text-lg font-semibold text-slate-900">Ask practical questions</h3>
        <p class="mt-3 text-slate-700">You can ask about timing, format, cancellations, and any practical concern before deciding to book.</p>
      </article>
    </div>
  </section>
</Layout>
