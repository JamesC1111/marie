---
import { getCollection, render } from 'astro:content';

import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getEntrySlug } from '../../lib/content';
import Layout from '../../layouts/Layout.astro';

const services = await getCollection('services');
const service = services.find(
  (entry) => getEntrySlug(entry.id) === Astro.params.slug
);

if (!service) {
  Astro.response.status = 404;
}

const renderedService = service ? await render(service) : null;
const Content = renderedService?.Content;
---

<Layout
  title={service?.data.metaTitle ?? 'Service not found'}
  description={service?.data.metaDescription ?? 'The requested service page could not be found.'}
  canonicalPath={service ? `/services/${getEntrySlug(service.id)}` : Astro.url.pathname}
>
  {service && Content ? (
    <>
      <div class="space-y-6">
        <Breadcrumbs
          items={[
            { label: 'Home', href: '/' },
            { label: 'Services', href: '/services' },
            { label: service.data.title }
          ]}
        />
        <PageHeader title={service.data.title} intro={service.data.summary} />
      </div>

      <article class="prose-safe mt-8">
        <Content />
      </article>

      <section class="mt-10 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Need urgent help?</h2>
        <p class="mt-2 text-slate-700">
          This practice is not an emergency service. If you need urgent help, call 112 or 999. Samaritans freephone 116 123.
        </p>
      </section>
    </>
  ) : (
    <section class="card mt-8">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Service page not found</h1>
      <p class="mt-4 text-slate-700">
        The page you were looking for is not available. You can return to the services page or contact Marie directly.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-primary" href="/services">View services</a>
        <a class="btn-secondary" href="/contact">Contact Marie</a>
      </div>
    </section>
  )}
</Layout>
