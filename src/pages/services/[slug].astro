---
import { getCollection, render } from 'astro:content';

import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PageHeader from '../../components/PageHeader.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import SupportPanel from '../../components/SupportPanel.astro';
import type { CollectionEntry } from 'astro:content';
import { getEntrySlug } from '../../lib/content';
import { relatedServicesBySlug, servicePageSections } from '../../lib/service-links';
import Layout from '../../layouts/Layout.astro';

const services = await getCollection('services');
const currentSlug = Astro.params.slug ?? '';
const service = services.find(
  (entry) => getEntrySlug(entry.id) === currentSlug
);

if (!service) {
  Astro.response.status = 404;
}

const renderedService = service ? await render(service) : null;
const Content = renderedService?.Content;
const relatedServices = service
  ? (relatedServicesBySlug[currentSlug] ?? [])
      .map((slug) =>
        services.find((entry) => getEntrySlug(entry.id) === slug)
      )
      .filter(
        (entry): entry is CollectionEntry<'services'> => entry !== undefined
      )
  : [];
---

<Layout
  title={service?.data.metaTitle ?? 'Service not found'}
  description={service?.data.metaDescription ?? 'The requested service page could not be found.'}
  canonicalPath={service ? `/services/${getEntrySlug(service.id)}` : Astro.url.pathname}
>
  {service && Content ? (
    <>
      <div class="space-y-6">
        <Breadcrumbs
          items={[
            { label: 'Home', href: '/' },
            { label: 'Services', href: '/services' },
            { label: service.data.title }
          ]}
        />
        <PageHeader title={service.data.title} intro={service.data.summary} />
      </div>

      <section class="section-shell mt-8 px-6 py-6 md:px-8">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
          <div class="max-w-3xl">
            <p class="section-kicker">Support in Kanturk, Co. Cork</p>
            <p class="mt-3 text-slate-700">
              If you are not sure whether this description fits exactly, you can still get in touch.
              Many people find that more than one concern overlaps.
            </p>
          </div>
          <p class="max-w-sm text-sm leading-relaxed text-slate-600">
            You do not need to explain everything in your first message. A short enquiry about availability is enough to begin.
          </p>
        </div>
      </section>

      <section class="service-layout mt-10 lg:grid-cols-[minmax(0,1fr)_18.5rem]">
        <article class="prose-safe service-prose">
          <Content />
        </article>

        <aside class="service-sidebar space-y-4">
          <section class="soft-panel">
            <p class="section-kicker">On this page</p>
            <ul class="service-links mt-4">
              {servicePageSections.map((section) => (
                <li>
                  <a href={section.href}>{section.label}</a>
                </li>
              ))}
            </ul>
          </section>

          <section class="soft-panel">
            <p class="section-kicker">How to start</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-700">
              If you would like to ask about availability, you can contact Marie by phone or email.
              A short message is enough.
            </p>
            <div class="mt-4 flex flex-col gap-3 text-sm font-medium">
              <a class="link-subtle" href="/contact" data-speculate="intent">Request appointment</a>
              <a class="link-subtle" href="/how-counselling-works" data-speculate="intent">How counselling works</a>
              <a class="link-subtle" href="/faq">Practical FAQs</a>
              <a class="link-subtle" href="/guides">Practical guides</a>
              <a class="link-subtle" href="/resources">Support resources</a>
            </div>
          </section>
        </aside>
      </section>

      {relatedServices.length > 0 && (
        <section class="mt-14">
          <div class="max-w-3xl">
            <p class="section-kicker">Related support</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">You may also want to read</h2>
          </div>
          <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {relatedServices.map((relatedService) => (
              <ServiceCard
                title={relatedService.data.title}
                summary={relatedService.data.summary}
                href={`/services/${getEntrySlug(relatedService.id)}/`}
              />
            ))}
          </div>
        </section>
      )}

      <div class="mt-14">
        <SupportPanel />
      </div>
    </>
  ) : (
    <section class="card mt-8">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900">Service page not found</h1>
      <p class="mt-4 text-slate-700">
        The page you were looking for is not available. You can return to the services page or contact Marie directly.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-primary" href="/services">View services</a>
        <a class="btn-secondary" href="/contact">Contact Marie</a>
      </div>
    </section>
  )}
</Layout>
