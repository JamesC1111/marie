---
import { getCollection } from 'astro:content';

import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHeader from '../components/PageHeader.astro';
import Layout from '../layouts/Layout.astro';

const resources = (await getCollection('resources')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="Resources"
  description="Useful Irish mental health resources and support information."
  canonicalPath="/resources"
>
  <div class="space-y-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Resources' }]} />
    <PageHeader
      title="Resources"
      intro="A short list of trusted Irish supports and information sources."
    />
  </div>

  <section class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <p class="text-slate-700">
      These links may be helpful for information and support.
      They are not a substitute for emergency or crisis care.
      If you need urgent help, call 112 or 999.
    </p>
  </section>

  <section class="mt-8 grid gap-5 md:grid-cols-2">
    {resources.map((resource) => (
      <article class="card h-full">
        <p class="text-sm font-medium text-teal-800">{resource.data.organisation}</p>
        <h2 class="mt-1 text-xl font-semibold text-slate-900">{resource.data.title}</h2>
        <p class="mt-3 text-slate-700">{resource.data.summary}</p>
        <p class="mt-3 text-slate-700">{resource.body}</p>
        <a
          class="mt-4 inline-flex text-sm font-semibold text-teal-800 underline-offset-2 hover:underline"
          href={resource.data.url}
          rel="noreferrer"
          target="_blank"
        >
          Visit website
        </a>
      </article>
    ))}
  </section>
</Layout>
