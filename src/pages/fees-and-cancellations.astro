---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHeader from '../components/PageHeader.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Fees and cancellations | Marie Harding"
  description="Current fee and cancellation information for Marie Harding Counselling Service in Kanturk, Co. Cork."
  canonicalPath="/fees-and-cancellations"
>
  <div class="space-y-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Fees and cancellations' }]} />
    <PageHeader
      title="Fees and cancellations"
      intro="Please contact Marie for current fees and appointment availability."
    />
  </div>

  <section class="soft-panel mt-8 px-6 py-6 md:px-8">
    <p class="text-slate-800">
      If you have a practical question before booking, please ask. It is often easier to start when the practical side feels clear.
    </p>
  </section>

  <section class="mt-8 grid gap-5 md:grid-cols-2">
    <article class="card">
      <h2 class="text-xl font-semibold text-slate-900">Current fees</h2>
      <p class="mt-3 text-slate-700">Please contact Marie for current fees.</p>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-slate-700">
        <li>Individual counselling session: €____</li>
        <li>Young person session: €____</li>
        <li>Professional supervision session: €____</li>
      </ul>
    </article>

    <article class="card">
      <h2 class="text-xl font-semibold text-slate-900">Cancellations</h2>
      <p class="mt-3 text-slate-700">
        If you need to cancel or move an appointment, please give as much notice as possible.
      </p>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-slate-700">
        <li>Notice requested: ____ hours</li>
        <li>Late cancellation fee: €____</li>
        <li>Missed appointment fee: €____</li>
      </ul>
      <p class="mt-4 text-slate-700">Please ask if you are unsure about cancellation terms before booking.</p>
    </article>
  </section>

  <section class="section-shell mt-10 px-6 py-8 md:px-8 md:py-8">
    <h2 class="text-xl font-semibold text-slate-900">Payment and practical details</h2>
    <p class="mt-3 max-w-3xl text-slate-700">
      Payment options and session scheduling can be confirmed when you contact Marie.
      If you have a practical concern, please ask and it can be discussed before your first session.
    </p>
  </section>
</Layout>
