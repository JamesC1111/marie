---
import { getCollection } from 'astro:content';

import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Layout from '../layouts/Layout.astro';
import { getEntrySlug } from '../lib/content';
import { localBusinessSchema, websiteSchema } from '../lib/schema';
import { practiceContact, serviceSignals } from '../lib/site';

const services = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

<Layout
  title="Counselling in Kanturk, Co. Cork"
  description="Confidential counselling support with Marie Harding in Kanturk, Co. Cork. Day and evening appointments available."
  canonicalPath="/"
  schema={[websiteSchema(), localBusinessSchema()]}
>
  <Hero
    title="Confidential counselling support in Kanturk, Co. Cork"
    intro="If things feel heavy, you do not have to carry them alone. I offer a calm, private space to talk through what is happening at your pace."
  />

  <section class="mt-12 grid gap-5 md:grid-cols-3">
    <article class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Experience you can trust</h2>
      <p class="mt-3 text-slate-700">Private practice since {serviceSignals.privatePracticeSince}, with HSE experience from {serviceSignals.hseExperience}.</p>
    </article>
    <article class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Local and accessible</h2>
      <p class="mt-3 text-slate-700">Practice based at {practiceContact.addressLine1}, {practiceContact.addressLine2}. {serviceSignals.openingNote}</p>
    </article>
    <article class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Professional supervision</h2>
      <p class="mt-3 text-slate-700">Marie is an {serviceSignals.supervision}.</p>
    </article>
  </section>

  <section class="mt-14 rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-sm md:p-8">
    <h2 class="text-2xl font-semibold tracking-tight text-slate-900">How to start</h2>
    <p class="mt-4 max-w-3xl text-slate-700">
      If you are considering counselling, the first step does not have to feel complicated.
      Read more about the process on the
      <a class="font-medium text-teal-800 underline underline-offset-4 transition hover:text-teal-900" href="/how-counselling-works">How counselling works</a>
      page.
    </p>
    <ol class="mt-6 grid gap-4 md:grid-cols-3">
      <li class="rounded-3xl border border-slate-200 bg-stone-50 p-6">
        <h3 class="text-lg font-semibold text-slate-900">Step 1</h3>
        <p class="mt-2 text-slate-700">Reach out by phone or email.</p>
      </li>
      <li class="rounded-3xl border border-slate-200 bg-stone-50 p-6">
        <h3 class="text-lg font-semibold text-slate-900">Step 2</h3>
        <p class="mt-2 text-slate-700">A short initial chat to see what you need and whether it feels like a fit.</p>
      </li>
      <li class="rounded-3xl border border-slate-200 bg-stone-50 p-6">
        <h3 class="text-lg font-semibold text-slate-900">Step 3</h3>
        <p class="mt-2 text-slate-700">Book a first session.</p>
      </li>
    </ol>
  </section>

  <section class="mt-14">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Services</h2>
      <a class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-800 transition hover:border-slate-400 hover:bg-slate-50" href="/services">View all services</a>
    </div>
    <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <div>
          <ServiceCard
            title={service.data.title}
            summary={service.data.summary}
            href={`/services/${getEntrySlug(service.id)}`}
          />
        </div>
      ))}
    </div>
  </section>
</Layout>
