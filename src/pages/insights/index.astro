---
import { getCollection } from "astro:content";

import ArticleCard from "../../components/ArticleCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PageHeader from "../../components/PageHeader.astro";
import Layout from "../../layouts/Layout.astro";
import {
  formatArticleDate,
  getReadingTime,
  getTagSlug,
  sortByPublishedDesc,
} from "../../lib/articles";
import { getEntrySlug } from "../../lib/content";

const insights = sortByPublishedDesc(await getCollection("insights"));
const featuredInsights = insights.filter((entry) => entry.data.featured).slice(0, 3);
const allTags = [...new Set(insights.flatMap((entry) => entry.data.tags))].sort();
---

<Layout
  title="Insights and updates | Marie Harding"
  description="Weekly-style practical articles on counselling questions, grief, anxiety, first sessions, and local support information."
  canonicalPath="/insights"
>
  <div class="space-y-6">
    <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Insights" }]} />
    <PageHeader
      title="Insights"
      intro="Practical, grounded articles for people considering counselling, supporting someone else, or looking for clearer guidance."
    />
  </div>

  {featuredInsights.length > 0 && (
    <section class="section-shell mt-8 px-6 py-8 md:px-8 md:py-10">
      <div class="max-w-3xl">
        <p class="section-kicker">Featured</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">
          Recent reading
        </h2>
      </div>
      <div class="article-grid mt-8">
        {featuredInsights.map((entry) => (
          <ArticleCard
            title={entry.data.title}
            summary={entry.data.summary}
            href={`/insights/${getEntrySlug(entry.id)}`}
            label={entry.data.category}
            meta={`${formatArticleDate(entry.data.published)} · ${getReadingTime(entry.body)} min read`}
          />
        ))}
      </div>
    </section>
  )}

  <section class="mt-14">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl">
        <p class="section-kicker">Browse by topic</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">
          Tags and themes
        </h2>
      </div>
      <ul class="tag-list">
        {allTags.map((tag) => (
          <li>
            <a href={`/insights/tags/${getTagSlug(tag)}`}>{tag}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="mt-10">
    <div class="article-grid">
      {insights.map((entry) => (
        <ArticleCard
          title={entry.data.title}
          summary={entry.data.summary}
          href={`/insights/${getEntrySlug(entry.id)}`}
          label={entry.data.category}
          meta={`${formatArticleDate(entry.data.published)} · ${getReadingTime(entry.body)} min read`}
        />
      ))}
    </div>
  </section>
</Layout>
