---
import { getCollection, render } from "astro:content";

import ArticleCard from "../../components/ArticleCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TagList from "../../components/TagList.astro";
import Layout from "../../layouts/Layout.astro";
import {
  formatArticleDate,
  getReadingTime,
  getRelatedArticles,
} from "../../lib/articles";
import { getEntrySlug } from "../../lib/content";
import { articleSchema } from "../../lib/schema";

const insights = await getCollection("insights");
const guides = await getCollection("guides");
const currentSlug = Astro.params.slug ?? "";
const insight = insights.find((entry) => getEntrySlug(entry.id) === currentSlug);

if (!insight) {
  Astro.response.status = 404;
}

const renderedInsight = insight ? await render(insight) : null;
const Content = renderedInsight?.Content;
const relatedInsights = insight
  ? getRelatedArticles(insights, insight.id, insight.data.tags)
  : [];
const relatedGuides = insight
  ? getRelatedArticles(guides, "", insight.data.tags).slice(0, 2)
  : [];
---

<Layout
  title={insight?.data.metaTitle ?? "Insight not found"}
  description={
    insight?.data.metaDescription ??
    "The insight you were looking for is not available."
  }
  canonicalPath={insight ? `/insights/${getEntrySlug(insight.id)}` : Astro.url.pathname}
  schema={
    insight
      ? [
          articleSchema({
            type: "BlogPosting",
            headline: insight.data.title,
            description: insight.data.metaDescription,
            url: new URL(
              `/insights/${getEntrySlug(insight.id)}`,
              "https://www.mariehardingcounselling.ie",
            ).toString(),
            published: insight.data.published,
            updated: insight.data.updated,
            keywords: insight.data.tags,
          }),
        ]
      : []
  }
>
  {insight && Content ? (
    <>
      <div class="space-y-6">
        <Breadcrumbs
          items={[
            { label: "Home", href: "/" },
            { label: "Insights", href: "/insights" },
            { label: insight.data.title },
          ]}
        />
        <header class="page-header">
          <p class="section-kicker">{insight.data.category}</p>
          <h1 class="mt-2 text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">
            {insight.data.title}
          </h1>
          <p class="page-lead mt-4 text-lg">{insight.data.summary}</p>
          <div class="article-meta mt-5">
            <span>{formatArticleDate(insight.data.published)}</span>
            <span>{getReadingTime(insight.body)} min read</span>
          </div>
          <div class="mt-4">
            <TagList tags={insight.data.tags} />
          </div>
        </header>
      </div>

      <section class="article-layout mt-10">
        <article class="prose-safe article-prose">
          <Content />
        </article>

        <aside class="article-sidebar space-y-4">
          <section class="soft-panel">
            <p class="section-kicker">Useful next steps</p>
            <div class="mt-4 flex flex-col gap-3 text-sm font-medium">
              <a class="link-subtle" href="/contact" data-speculate="intent">
                Request appointment
              </a>
              <a class="link-subtle" href="/guides">Read longer guides</a>
              <a class="link-subtle" href="/resources">Support resources</a>
            </div>
          </section>
        </aside>
      </section>

      {relatedInsights.length > 0 && (
        <section class="mt-14">
          <div class="max-w-3xl">
            <p class="section-kicker">Related insights</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">
              More articles on nearby themes
            </h2>
          </div>
          <div class="article-grid mt-8">
            {relatedInsights.map((entry) => (
              <ArticleCard
                title={entry.data.title}
                summary={entry.data.summary}
                href={`/insights/${getEntrySlug(entry.id)}`}
                label={entry.data.category}
                meta={`${formatArticleDate(entry.data.published)} - ${getReadingTime(entry.body)} min read`}
              />
            ))}
          </div>
        </section>
      )}

      {relatedGuides.length > 0 && (
        <section class="mt-14">
          <div class="max-w-3xl">
            <p class="section-kicker">Related guides</p>
            <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 md:text-3xl">
              Longer reading if you want more detail
            </h2>
          </div>
          <div class="article-grid mt-8">
            {relatedGuides.map((entry) => (
              <ArticleCard
                title={entry.data.title}
                summary={entry.data.summary}
                href={`/guides/${getEntrySlug(entry.id)}`}
                label={entry.data.category}
                meta={`${formatArticleDate(entry.data.published)} - ${getReadingTime(entry.body)} min read`}
              />
            ))}
          </div>
        </section>
      )}
    </>
  ) : (
    <section class="card mt-8">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900">
        Insight not found
      </h1>
      <p class="mt-4 text-slate-700">
        The article you were looking for is not available. You can return to
        the insights page or contact Marie directly.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-primary" href="/insights">View insights</a>
        <a class="btn-secondary" href="/contact">Contact Marie</a>
      </div>
    </section>
  )}
</Layout>
